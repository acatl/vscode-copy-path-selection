{
  "name": "copy-path-selection",
  "displayName": "Copy Path and Selection",
  "description": "Copies the file path and selection range to the clipboard in a compact format — ideal for referencing code in AI assistants.",
  "version": "0.0.2",
  "publisher": "acatl",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "clipboard",
    "path",
    "selection",
    "AI",
    "reference",
    "copy",
    "copilot"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-path-selection.copySelection",
        "title": "Copy Selection Reference for Model",
        "category": "Copy Path"
      }
    ],
    "keybindings": [
      {
        "command": "copy-path-selection.copySelection",
        "key": "ctrl+alt+shift+c",
        "mac": "ctrl+alt+cmd+c",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "copy-path-selection.copySelection",
          "when": "editorTextFocus",
          "group": "9_cutcopypaste"
        }
      ]
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/acatl/vscode-copy-path-selection.git"
  },
  "homepage": "https://github.com/acatl/vscode-copy-path-selection#readme",
  "bugs": {
    "url": "https://github.com/acatl/vscode-copy-path-selection/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
